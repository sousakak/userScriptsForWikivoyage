        {
            "value": "contact",
            "label": "Contact",
            "active": true,
            "params": {
                "url": {
                    "title": "Url",
                    "widget": "input",
                    "placeholder": true,
                    "validate": "\/^https?:\\\/\\\/[-_.!~*\\'()a-zA-Z0-9;\\\/?:\\@&=+\\$,%#\\u3000-\\u30FE\\u4E00-\\u9FA0\\uFF01-\\uFFE3]+\\/?$\/"
                },
                "phone": {
                    "title": "Phone number",
                    "widget": "input",
                    "placeholder": true,
                    "validate": "\/^\\+?[0-9\\s]{1,4}([-\\s]?[0-9]{1,4})*(\\uff08.+?\\uff09)?([,\\u3001]\\s?\\+?[0-9]{1,4}(\\-[0-9]{1,4})*)*$\/"
                },
                "tollfree": {
                    "title": "Tollfree",
                    "widget": "input",
                    "placeholder": true
                },
                "mobile": {
                    "title": "Mobile Phone Number",
                    "widget": "input",
                    "placeholder": true,
                    "validate": "\/^0[5789]0[-\\s]?\\d{4}[-\\s]?\\d{4}$\/"
                },
                "fax": {
                    "title": "Fax",
                    "widget": "input",
                    "placeholder": true
                },
                "email": {
                    "title": "Email Address",
                    "widget": "input",
                    "placeholder": true,
                    "validate": "\/^[\\w\\+\\-]+(.[\\w\\+\\-]+)*@([a-zA-Z0-9][a-zA-Z0-9-]*[a-zA-Z0-9]*\\.)+[a-zA-Z]{2,}$\/"
                }
            }
